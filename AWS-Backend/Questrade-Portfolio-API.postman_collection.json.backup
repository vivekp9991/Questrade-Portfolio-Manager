                  "description": "Filter by person name",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "completed",
                  "description": "Filter by status (completed, failed, in_progress)",
                  "disabled": true
                },
                {
                  "key": "syncType",
                  "value": "full",
                  "description": "Filter by sync type (full, accounts, positions, activities)",
